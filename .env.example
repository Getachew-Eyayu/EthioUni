# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ethiouni"

# NextAuth Configuration
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (Optional)
GITHUB_ID="your-github-oauth-id"
GITHUB_SECRET="your-github-oauth-secret"
GOOGLE_ID="your-google-oauth-id"
GOOGLE_SECRET="your-google-oauth-secret"

# Cloudinary (Image Management)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Resend (Email Service)
RESEND_API_KEY="your-resend-api-key"
NEXT_PUBLIC_RESEND_FROM_EMAIL="noreply@ethiouni.com"

# OpenAI (AI Features)
OPENAI_API_KEY="your-openai-api-key"

# Leaflet Maps (Optional)
NEXT_PUBLIC_LEAFLET_API_KEY="your-leaflet-api-key"

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="EthioUni"
